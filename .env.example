# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

# LLM provider API keys (at least one required)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...

# Channel integrations (optional)
# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# HTTP adapter (REST + SSE interface)
# THAT_HTTP_PORT=8080
# THAT_HTTP_BEARER_TOKEN=

# Phoenix observability (optional)
# Set PHOENIX_TRACING=true to enable structured OTel trace export.
# Phoenix self-hosted defaults to http://localhost:6006
# PHOENIX_TRACING=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:6006
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:6006/v1/traces
# PHOENIX_LOG_LEVEL=info
# PHOENIX_EVAL_ANNOTATIONS=true

# Optional overrides
# THAT_AGENT_MODEL=
# THAT_AGENT_PROVIDER=
# THAT_AGENT_MAX_TURNS=
# THAT_AGENT_PROFILE=
# OpenAI transport mode: true (default) = WebSocket, false = legacy HTTP streaming
# THAT_OPENAI_WEBSOCKET=true
